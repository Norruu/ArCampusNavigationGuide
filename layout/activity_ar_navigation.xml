<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="#000000">

    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/sceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigating to:"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:shadowColor="#000000"
            android:shadowRadius="8"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvTargetName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Alumni Building"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowRadius="8"/>

        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="509 m"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowRadius="8"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExitAr"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_margin="24dp"
        android:text="Exit"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:backgroundTint="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelNavigation"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:text="Cancel"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="#FF3B30"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnExitAr"
        app:layout_constraintEnd_toEndOf="parent" />

    <Space
        android:id="@+id/radarCenterAnchor"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="1.0"
        app:layout_constraintDimensionRatio="1:1"
        app:cardCornerRadius="25dp"
        app:strokeWidth="4dp"
        app:strokeColor="#FFFFFF"
        app:cardElevation="24dp"
        app:layout_constraintTop_toTopOf="@id/radarCenterAnchor"
        app:layout_constraintBottom_toBottomOf="@id/radarCenterAnchor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <org.osmdroid.views.MapView
            android:id="@+id/miniMapView"
            android:layout_width="match_parent"
            android:layout_height="444dp" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>