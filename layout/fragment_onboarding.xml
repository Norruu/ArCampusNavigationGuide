<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_mint_light"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Topographic pattern background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.25"
        android:src="@drawable/bg_topographic_pattern"
        android:importantForAccessibility="no" />

    <!-- Main content column -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ===== TOP LEFT: Title ===== -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="28dp"
            android:layout_marginTop="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Personal"
                android:textColor="@color/primary_green_dark"
                android:textSize="32sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPSU guide"
                android:textColor="@color/primary_green"
                android:textSize="40sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <!-- ===== RIGHT SIDE: Category card peeking from right ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="-60dp"
                android:rotation="-4"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Fake search bar -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/card_bg_light"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_search"
                                app:tint="#AAAAAA"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Search for place"
                                android:textColor="#AAAAAA"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Fake category chips -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="All"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:chipBackgroundColor="@color/primary_green"
                            app:chipCornerRadius="18dp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:text="Dept."
                            android:textSize="12sp"
                            app:chipBackgroundColor="@color/chip_bg_light"
                            app:chipCornerRadius="18dp"
                            android:clickable="false" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:text="Acad."
                            android:textSize="12sp"
                            app:chipBackgroundColor="@color/chip_bg_light"
                            app:chipCornerRadius="18dp"
                            android:clickable="false" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="0.6" />

        <!-- ===== LEFT SIDE: 100M card peeking from left ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginStart="-25dp"
                android:rotation="3"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="-0.03"
                            android:text="100 M"
                            android:textColor="@color/primary_green_dark"
                            android:textSize="48sp"
                            android:textStyle="bold|italic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Turn right"
                            android:textColor="@color/primary_green"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:layout_marginTop="-6dp" />

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.5" />

        <!-- ===== START Button ===== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="48dp"
            android:text="START"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:backgroundTint="@color/primary_green"
            app:cornerRadius="16dp"
            app:elevation="6dp" />

    </LinearLayout>

</FrameLayout>