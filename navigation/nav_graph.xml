<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <!-- 🆕 Onboarding / Splash -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.campus.arnav.ui.onboarding.OnboardingFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_onboarding">

        <action
            android:id="@+id/action_onboarding_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 🆕 Dashboard -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.campus.arnav.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_map"
            app:destination="@id/mapFragment" />

        <action
            android:id="@+id/action_dashboard_to_search"
            app:destination="@id/searchFragment" />

        <action
            android:id="@+id/action_dashboard_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <!-- Map Fragment -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.campus.arnav.ui.map.MapFragment"
        android:label="Map"
        tools:layout="@layout/fragment_map">

        <action
            android:id="@+id/action_mapFragment_to_searchFragment"
            app:destination="@id/searchFragment" />

        <action
            android:id="@+id/action_mapFragment_to_arNavigationFragment"
            app:destination="@id/arNavigationFragment" />

        <action
            android:id="@+id/action_mapFragment_to_buildingDetailFragment"
            app:destination="@id/buildingDetailFragment" />

        <action
            android:id="@+id/action_mapFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />

        <action
            android:id="@+id/action_map_to_dashboard"
            app:destination="@id/dashboardFragment" />

        <!-- 🆕 Accept building ID for navigation -->
        <argument
            android:name="navigateToBuildingId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <!-- Search Fragment -->
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.campus.arnav.ui.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">

        <action
            android:id="@+id/action_searchFragment_to_buildingDetailFragment"
            app:destination="@id/buildingDetailFragment" />

        <action
            android:id="@+id/action_searchFragment_to_mapFragment"
            app:destination="@id/mapFragment"
            app:popUpTo="@id/mapFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- Building Detail Fragment -->
    <fragment
        android:id="@+id/buildingDetailFragment"
        android:name="com.campus.arnav.ui.building.BuildingDetailFragment"
        android:label="Building Details"
        tools:layout="@layout/fragment_building_detail">

        <argument
            android:name="buildingId"
            app:argType="string" />

        <action
            android:id="@+id/action_buildingDetailFragment_to_arNavigationFragment"
            app:destination="@id/arNavigationFragment" />
    </fragment>

    <!-- AR Navigation Fragment -->
    <fragment
        android:id="@+id/arNavigationFragment"
        android:name="com.campus.arnav.ui.ar.ARNavigationFragment"
        android:label="AR Navigation"
        tools:layout="@layout/fragment_ar_navigation">

        <argument
            android:name="routeId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <!-- Settings Fragment -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.campus.arnav.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>